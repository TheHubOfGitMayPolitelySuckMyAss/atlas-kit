{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_DIR:-.}/.claude/hooks/atlas-open-loop-sweep.sh\"",
            "timeout": 10,
            "statusMessage": "Atlas open-loop sweep"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_DIR:-.}/.claude/hooks/atlas-kit-update-check.sh\"",
            "timeout": 15,
            "statusMessage": "Atlas kit update check"
          }
        ]
      }
    ]
  }
}
